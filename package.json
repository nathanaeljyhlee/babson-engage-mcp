{
  "name": "babson-engage-mcp",
  "version": "2.0.0",
  "description": "MCP server exposing Babson Engage RSS feeds for AI agents",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "babson-engage-mcp": "dist/server.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "start:http": "node dist/server-http.js",
    "start:azure": "node dist/server-azure.js",
    "dev": "tsx src/server.ts",
    "dev:http": "tsx src/server-http.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.22.1",
    "express-rate-limit": "^8.5.1",
    "fast-xml-parser": "^5.2.0",
    "helmet": "^8.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}

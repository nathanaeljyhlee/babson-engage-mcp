name: Deploy demo to Azure Static Web Apps

# To activate: rename this file to azure-static-web-app-deploy.yml and add the
# AZURE_STATIC_WEB_APPS_API_TOKEN secret (see README "Migrating to GitHub Actions").

on:
  push:
    branches: [main]
    paths:
      - 'demo/**'
  workflow_dispatch:

jobs:
  deploy:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Deploy to Azure Static Web Apps
        uses: Azure/static-web-apps-deploy@v1
        with:
          azure_static_web_apps_api_token: ${{ secrets.AZURE_STATIC_WEB_APPS_API_TOKEN }}
          repo_token: ${{ secrets.GITHUB_TOKEN }}
          action: 'upload'
          app_location: '/demo'
          output_location: ''
          skip_app_build: true
